# Upstream Paridhan Express API (no path suffix)
BACKEND_URL=http://127.0.0.1:5000

# Port clients (e.g. Next.js) should call
GATEWAY_PORT=4000
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production

# Gateway-side Redis cache for product reads
REDIS_URL=redis://127.0.0.1:6379
REDIS_CACHE_PREFIX=paridhan-gateway
REDIS_AUTH_PREFIX=paridhan:auth
REDIS_PRODUCT_LIST_TTL=300
REDIS_PRODUCT_SINGLE_TTL=600
# Home hero payload cache (seconds)
REDIS_HERO_TTL=300
